#!/bin/bash
#
# Script to generate language bindings for a proto API.
#
# Usage:
#   ./script/generate -a <api> [-v <version>]
#
# Options:
#   -a, --api <api>     The API to generate bindings for
#   -v, --version <version> The version of the API to generate bindings for
#
# Example:
#   ./script/generate -a multi_agent -v v1

set -e

API=""
VERSION="v1"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -a|--api)
      API="$2"
      shift 2
      ;;
    -v|--version)
      VERSION="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

if [ -z "$API" ]; then
  echo "Error: API (-a|--api) is required"
  echo "Available APIs:"
  APIS=($(ls -1 apis))
  for api in "${APIS[@]}"; do
    echo " - $api"
  done
  exit 1
fi

if [ -z "$VERSION" ]; then
  echo "Error: Version (-v|--version) is required"
  exit 1
fi

echo "Generating bindings for $API $VERSION..."

echo "Source protos:"
API_PATH="apis/$API/$VERSION"
PROTO_FILES=($(cd "$API_PATH" > /dev/null && ls -1 *.proto))
for proto in "${PROTO_FILES[@]}"; do
  echo " - $API_PATH/$proto"
done

echo -e "\n➡️  Generating Go bindings..."
protoc --go_out="apis/$API" --go_opt="module=github.com/warpdotdev/warp-proto-apis/apis/$API" --proto_path="$(realpath "$API_PATH")" "${PROTO_FILES[@]}"
pushd "apis/$API" >/dev/null 2>&1
go mod tidy
popd >/dev/null 2>&1

echo "✅️ Done generating Go bindings"

echo -e "\n➡️  Generating Python bindings..."

# Preprocess proto files to strip Go-specific directives (mirrors the approach in the Rust build.rs).
PYTHON_TEMP_DIR=$(mktemp -d)
trap "rm -rf $PYTHON_TEMP_DIR" EXIT

for proto in "${PROTO_FILES[@]}"; do
  sed -e '/import "google\/protobuf\/go_features.proto";/d' \
      -e '/option features\.(pb\.go)/d' \
      -e '/option go_package/d' \
      "$API_PATH/$proto" > "$PYTHON_TEMP_DIR/$proto"
done
PYTHON_OUT="$API_PATH/gen/python"

protoc --python_out="$PYTHON_OUT" --pyi_out="$PYTHON_OUT" \
  --proto_path="$PYTHON_TEMP_DIR" \
  "${PROTO_FILES[@]}"

# Fix imports: protoc generates absolute imports (e.g. `import foo_pb2`) which
# don't work when installed as a package. Convert them to relative imports.
for f in "$PYTHON_OUT"/*_pb2.py "$PYTHON_OUT"/*_pb2.pyi; do
  [ -f "$f" ] || continue
  sed -i '' 's/^import \([a-z_]*_pb2\)/from . import \1/' "$f"
done

# Generate __init__.py that re-exports all generated modules.
INIT_FILE="$PYTHON_OUT/__init__.py"
echo '# Auto-generated by script/generate. Do not edit.' > "$INIT_FILE"
for proto in "${PROTO_FILES[@]}"; do
  MODULE="${proto%.proto}_pb2"
  echo "from . import $MODULE" >> "$INIT_FILE"
done

echo "✅️ Done generating Python bindings"
